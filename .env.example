# === Flow ===
FLOW_EVM_RPC_URL=https://mainnet.evm.nodes.onflow.org
FLOW_PRIVATE_KEY=0x...your_private_key_here
FLOW_SMART_ACCOUNT_ADDRESS=0x...your_wallet_address_here
FLOW_ACCESS_NODE=https://rest-mainnet.onflow.org

# === FlowVault Contracts ===
DELEGATION_RULES_ADDRESS=0x...deployed_contract_address
EXPENSE_RESERVE_ADDRESS=0x...deployed_contract_address
DAO_MULTISIG_ADDRESS=0x...deployed_contract_address

# === IncrementFi (DEX on Flow) ===
INCREMENT_ROUTER_ADDRESS=0x...incrementfi_router_address

# === Pyth Network ===
PYTH_CONTRACT_FLOW=0x2880aB155794e7179c9eE2e38200202908C17B43

# === Hermes LLM (NousResearch) ===
HERMES_API_KEY=sk-...
HERMES_BASE_URL=https://inference-api.nousresearch.com/v1
HERMES_MODEL=hermes-4-70b

# === Redis ===
REDIS_URL=redis://localhost:6379

# === Telegram ===
TELEGRAM_BOT_TOKEN=...your_bot_token_from_botfather
TELEGRAM_CHAT_ID=...your_chat_id

# === Filecoin / Lighthouse (audit log) ===
LIGHTHOUSE_API_KEY=...your_lighthouse_api_key

# === Self Protocol (identity verification) ===
SELF_APP_SCOPE=flowvault
SELF_VERIFICATION_ENDPOINT=https://your-domain.com/api/self/verify
NEXT_PUBLIC_SELF_APP_SCOPE=flowvault
NEXT_PUBLIC_SELF_VERIFICATION_ENDPOINT=https://your-domain.com/api/self/verify

# === App ===
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_FLOW_ACCESS_NODE=https://rest-mainnet.onflow.org
NEXT_PUBLIC_FLOW_WALLET_DISCOVERY=https://fcl-discovery.onflow.org/authn
